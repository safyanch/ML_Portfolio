   ],
   "source": [
    "# Save full conversation to text file\n",
    "import pandas as pd\n",
    "os.makedirs('data', exist_ok=True)\n",
    "\n",
    "with open('data/day10_conversation.txt', 'w') as f:\n",
    "    f.write(\"=== Day 10 — ML Tutor Conversation Log ===\\n\\n\")\n",
    "    for turn in conversation_log:\n",
    "        f.write(f\"Turn {turn['turn']}\\n\")\n",
    "        f.write(f\"Student: {turn['student']}\\n\")\n",
    "        f.write(f\"Tutor:   {turn['tutor']}\\n\")\n",
    "        f.write(\"-\"*50 + \"\\n\\n\")\n",
    "\n",
    "print(\"Conversation saved ✓\")\n",
    "\n",
    "# Save conversation as DataFrame too\n",
    "df_conv = pd.DataFrame(conversation_log)\n",
    "df_conv.to_csv('data/day10_conversation.csv', index=False)\n",
    "print(\"Conversation CSV saved ✓\")\n",
    "\n",
    "# Final summary\n",
    "print(\"\\n=== Day 10 Summary ===\")\n",
    "print(\"✅ LangChain installed and running\")\n",
    "print(\"✅ First chain built — PromptTemplate | LLM | OutputParser\")\n",
    "print(\"✅ 3 prompt templates — explainer, quiz generator, summarizer\")\n",
    "print(\"✅ Conversation memory working — tutor remembers student name\")\n",
    "print(\"✅ All outputs saved to /data folder\")"
   ]
