  {
   "cell_type": "markdown",
   "id": "af27c369-7539-432f-9b72-6da5de8e3f49",
   "metadata": {},
   "source": [
    "## Prompt Templates — Reusable AI Tools\n",
    "Each template is a reusable function. Change the input variables and get a different output. No code duplication."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0723cbb0-d901-4ce1-9017-e5b79833d000",
   "metadata": {},
   "outputs": [],
   "source": [
    "# create template\n",
    "prompt=ChatPromptTemplate.from_messages([(\n",
    "    \"system\", \"\"\" you are Dr. Muhammad Safyan, Associate Professor of ML/AI with 15 years of experience.\n",
    "    explian the concept clearly using:\n",
    "    1. simple defination\n",
    "    2. real-world analogy\n",
    "    3. one practical example\n",
    "    keep under 150 words. \"\"\"),\n",
    "                                         (\"user\", \"explain the ML concept: {concept}\")])\n",
    "parser=StrOutputParser()\n",
    "chain=prompt|llm|parser\n",
    "concepts=[\"Random Forest\", \"BackPropogation\", \" Attention Mechanisim\"]\n",
    "for concept in concepts:\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\" concept={concept}\")\n",
    "    print(f\"\\n{'='*50}\")   \n",
    "    ch=chain.invoke({\"concept\": concept})\n",
    "    print(ch)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "255551de-115e-4b4f-ae12-a4617a3a0db5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Template 2: Quiz Generator\n",
    "prompt=ChatPromptTemplate.from_messages([(\n",
    "    \"system\", \"\"\"you are ML quiz generator.\n",
    "    generate exactly 5 MCQs.\n",
    "    format each question as \n",
    "    Q1: [question]\n",
    "    A) [option] B) [option] C [option] D [option]\n",
    "    Answer: [correct letter]\n",
    "    Difficulty : {difficulty}\"\"\"),\n",
    "                                         ('user', \"Generate 5 MCQs on {topic}\")\n",
    "                                        ])\n",
    "parser=StrOutputParser()\n",
    "chain=prompt|llm|parser\n",
    "topics=[{\"topic\": \"Neural Networks\",    \"difficulty\": \"Intermediate\"},\n",
    "    {\"topic\": \"Decision Trees\",     \"difficulty\": \"Beginner\"}\n",
    "]\n",
    "for t in topics:\n",
    "    print(f\"\\n {'='*50}\")\n",
    "    print(f\" Quiz: {t['topic']} | Level:{t['difficulty']}\")\n",
    "    print(f\"\\n {'='*50}\")\n",
    "    quiz=chain.invoke(t)\n",
    "    print(quiz)\n",
    "    "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "36899205-6434-4dc3-a1d4-2920431fdfdc",
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
