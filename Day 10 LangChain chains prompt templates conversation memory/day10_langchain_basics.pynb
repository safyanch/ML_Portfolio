   "source": [
    "import os\n",
    "os.environ['GROQ_API_KEY']=\"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\"\n",
    "key=os.getenv(\"GROQ_API_KEY\")\n",
